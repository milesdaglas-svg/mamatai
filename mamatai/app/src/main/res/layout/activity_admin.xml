<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a0a">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#111111">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📶 MAMA.TAI"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#ffffff"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● LIVE"
            android:textSize="12sp"
            android:textColor="#00c853"
            android:background="@drawable/badge_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"/>
    </LinearLayout>

    <!-- Tab bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#111111">
        <Button android:id="@+id/tab_dashboard" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="📊\nDash" android:textSize="10sp" android:background="?attr/selectableItemBackground" android:textColor="#ffffff"/>
        <Button android:id="@+id/tab_vouchers"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="🎫\nVouchers" android:textSize="10sp" android:background="?attr/selectableItemBackground" android:textColor="#888888"/>
        <Button android:id="@+id/tab_users"     android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="👥\nUsers" android:textSize="10sp" android:background="?attr/selectableItemBackground" android:textColor="#888888"/>
        <Button android:id="@+id/tab_settings"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="⚙️\nSettings" android:textSize="10sp" android:background="?attr/selectableItemBackground" android:textColor="#888888"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- DASHBOARD PAGE -->
            <LinearLayout android:id="@+id/page_dashboard" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="visible">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/card_bg" android:padding="14dp" android:layout_marginEnd="6dp">
                        <TextView android:id="@+id/tv_active_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#00c853"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Active users" android:textSize="11sp" android:textColor="#666"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/card_bg" android:padding="14dp" android:layout_marginStart="6dp">
                        <TextView android:id="@+id/tv_total_users" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#ffffff"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total users" android:textSize="11sp" android:textColor="#666"/>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/card_bg" android:padding="14dp" android:layout_marginEnd="6dp">
                        <TextView android:id="@+id/tv_revenue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UGX 0" android:textSize="16sp" android:textStyle="bold" android:textColor="#ffffff"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Revenue" android:textSize="11sp" android:textColor="#666"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/card_bg" android:padding="14dp" android:layout_marginStart="6dp">
                        <TextView android:id="@+id/tv_voucher_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="28sp" android:textStyle="bold" android:textColor="#ffffff"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vouchers sold" android:textSize="11sp" android:textColor="#666"/>
                    </LinearLayout>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_users"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_bg"
                    android:padding="8dp"/>
            </LinearLayout>

            <!-- VOUCHERS PAGE -->
            <LinearLayout android:id="@+id/page_vouchers" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:padding="16dp" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CREATE VOUCHER" android:textSize="11sp" android:textColor="#666" android:layout_marginBottom="12dp"/>
                    <EditText android:id="@+id/et_name" android:layout_width="match_parent" android:layout_height="48dp" android:hint="Customer name (optional)" android:textColor="#fff" android:textColorHint="#555" android:background="@drawable/input_bg" android:paddingHorizontal="12dp" android:layout_marginBottom="10dp"/>
                    <Spinner android:id="@+id/sp_data" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/input_bg" android:layout_marginBottom="10dp"/>
                    <Spinner android:id="@+id/sp_time" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/input_bg" android:layout_marginBottom="10dp"/>
                    <EditText android:id="@+id/et_price" android:layout_width="match_parent" android:layout_height="48dp" android:hint="Price in UGX" android:textColor="#fff" android:textColorHint="#555" android:inputType="number" android:background="@drawable/input_bg" android:paddingHorizontal="12dp" android:layout_marginBottom="14dp"/>
                    <Button android:id="@+id/btn_generate" android:layout_width="match_parent" android:layout_height="48dp" android:text="Generate Voucher" android:backgroundTint="#00c853" android:textColor="#000" android:textStyle="bold"/>
                </LinearLayout>

                <!-- New code card -->
                <LinearLayout android:id="@+id/card_new_code" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:padding="16dp" android:layout_marginBottom="12dp" android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SHARE THIS CODE" android:textSize="11sp" android:textColor="#666" android:layout_marginBottom="10dp"/>
                    <TextView android:id="@+id/tv_new_code" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="28sp" android:textStyle="bold" android:textColor="#00c853" android:gravity="center" android:fontFamily="monospace" android:background="@drawable/input_bg" android:padding="14dp" android:layout_marginBottom="10dp"/>
                    <Button android:id="@+id/btn_copy_code" android:layout_width="match_parent" android:layout_height="44dp" android:text="Copy Code" android:backgroundTint="#1a1a1a" android:textColor="#fff"/>
                </LinearLayout>
            </LinearLayout>

            <!-- USERS PAGE -->
            <LinearLayout android:id="@+id/page_users" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_users_full"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_bg"
                    android:padding="8dp"/>
            </LinearLayout>

            <!-- SETTINGS PAGE -->
            <LinearLayout android:id="@+id/page_settings" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SETTINGS" android:textSize="11sp" android:textColor="#666" android:layout_marginBottom="12dp"/>
                    <EditText android:id="@+id/et_ssid" android:layout_width="match_parent" android:layout_height="48dp" android:hint="WiFi name (SSID)" android:textColor="#fff" android:textColorHint="#555" android:background="@drawable/input_bg" android:paddingHorizontal="12dp" android:layout_marginBottom="10dp"/>
                    <EditText android:id="@+id/et_biz" android:layout_width="match_parent" android:layout_height="48dp" android:hint="Business name" android:textColor="#fff" android:textColorHint="#555" android:background="@drawable/input_bg" android:paddingHorizontal="12dp" android:layout_marginBottom="14dp"/>
                    <Button android:layout_width="match_parent" android:layout_height="48dp" android:text="Save Settings" android:backgroundTint="#00c853" android:textColor="#000" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
